# Copy this file to .env (do NOT commit .env)
#
# Basic backend Docker run works without most of these.
# Fill only what you need.

# SQL Server (used by docker-compose.yml)
MSSQL_SA_PASSWORD=FuelFlow_SA_Password!123

# Mail (used for OTP emails; Identity service reads MailSettings)
MAILSETTINGS__ENABLED=false
MAILSETTINGS__SMTPHOST=
MAILSETTINGS__SMTPPORT=587
MAILSETTINGS__USESSL=true
MAILSETTINGS__USERNAME=
MAILSETTINGS__FROMEMAIL=
MAILSETTINGS__PASSWORD=
MAILSETTINGS__FROMNAME=Fuel Flow

# AI Assistant (Gateway: /gateway/ai/chat)
AI_ASSISTANT_API_KEY=

# Razorpay Payments (Gateway: /gateway/payments/*)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
